# Monorepo-wide ignores for the automations repo.
# Project-local rules can live in each subproject's own .gitignore (e.g. brief-me/.gitignore).

# --- macOS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node (for future automations) ---
node_modules/
npm-debug.log*
yarn-*.log*
.pnpm-debug.log*

# --- Secrets / env (defense in depth — never commit credentials) ---
.env
.env.*
*.local
*.pem
*.key

# --- Logs & temp ---
*.log
*.tmp

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
